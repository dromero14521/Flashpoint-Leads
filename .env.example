# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Stripe Price IDs (Get these from Stripe Dashboard → Products)
# Tier 2: Core Subscription (Recurring)
STRIPE_PRICE_TIER2_MONTHLY_99=price_xxxxxxxxxxxx
STRIPE_PRICE_TIER2_MONTHLY_199=price_xxxxxxxxxxxx

# Tier 3: Apex Implementation (One-time)
STRIPE_PRICE_TIER3_ONETIME_2500=price_xxxxxxxxxxxx
STRIPE_PRICE_TIER3_ONETIME_5000=price_xxxxxxxxxxxx

# Legacy naming (for backward compatibility)
STRIPE_ARCHITECT_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_ARCHITECT_YEARLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_APEX_PRICE_ID=price_xxxxxxxxxxxx

# Database (PostgreSQL required for multi-tenant row-level security)
DATABASE_URL="postgresql://user:password@localhost:5432/aaa_dev"
# For local development with SQLite (limited multi-tenant features):
# DATABASE_URL="file:./dev.db"

# URLs
NEXT_PUBLIC_URL=http://localhost:3000

# OpenRouter (GenAI Core)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Set to true to skip LLM calls during development
USE_MOCK_LLM=true
