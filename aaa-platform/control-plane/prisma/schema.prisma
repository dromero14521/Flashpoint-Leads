generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(cuid())
  clerkId   String  @unique
  email     String  @unique
  firstName String?
  lastName  String?
  imageUrl  String?

  // Multi-Tenant (userId is the tenantId in B2C model)
  tenantId String @default("") // For future B2B multi-user tenants

  // Subscription
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  tier                   String    @default("free") // free, architect, apex

  // Referrals
  referralCode  String? @unique
  referredBy    String?
  referralCount Int     @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  blueprints Blueprint[]
  settings   UserSettings?

  @@index([tenantId])
}

model Blueprint {
  id       String @id @default(cuid())
  userId   String
  tenantId String // For tenant isolation
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Input
  industry    String
  revenueGoal String
  techStack   String // JSON string
  painPoints  String

  // Output
  strategicDiagnosis   String?
  proposedArchitecture String?
  components           String? // JSON string
  automationSteps      String? // JSON string
  estimatedImpact      String?
  rawBlueprint         String? // Full JSON response

  // Metadata
  status     String  @default("draft") // draft, generated, implemented
  isFavorite Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId, tenantId])
}

model UserSettings {
  id       String @id @default(cuid())
  userId   String @unique
  tenantId String // For tenant isolation
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notifications
  emailNotifications Boolean @default(true)
  marketingEmails    Boolean @default(false)
  weeklyDigest       Boolean @default(true)

  // Preferences
  defaultModel String @default("anthropic/claude-3.5-sonnet")
  timezone     String @default("America/New_York")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Lead {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String?
  lastName  String?
  company   String?
  industry  String?

  // Lead source
  source     String  @default("organic") // organic, referral, cold, content
  leadMagnet String? // which lead magnet they downloaded

  // Qualification
  estimatedRevenue String?
  painPoints       String?
  status           String  @default("new") // new, contacted, qualified, converted, lost

  // Tracking
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StrategyCall {
  id String @id @default(cuid())

  // Contact Info
  email     String
  firstName String
  lastName  String?
  company   String?
  phone     String?

  // Business Info
  industry String
  revenue  String?
  teamSize String?

  // Pain & Goals
  biggestChallenge String
  desiredOutcome   String
  timeline         String?

  // Scheduling
  preferredDate DateTime?
  preferredTime String?
  timezone      String?

  // Status
  status    String  @default("pending") // pending, confirmed, completed, no-show, converted
  notes     String?
  outcome   String? // won, lost, postponed
  dealValue Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditSubmission {
  id    String @id @default(cuid())
  email String

  // Audit Answers
  industry           String
  monthlyRevenue     String
  hoursOnManualTasks Int
  hourlyRate         Float?
  topPainPoints      String // JSON array
  currentTools       String // JSON array
  automationAttempts String?

  // Calculated
  annualCost       Float?
  potentialSavings Float?

  createdAt DateTime @default(now())
}

model WebhookEvent {
  id            String  @id @default(cuid())
  stripeEventId String  @unique
  eventType     String
  processed     Boolean @default(false)
  attempts      Int     @default(0)
  lastError     String?

  createdAt   DateTime  @default(now())
  processedAt DateTime?
}

model SubscriptionHistory {
  id       String @id @default(cuid())
  userId   String
  tenantId String // For tenant isolation

  // Subscription details
  stripeSubscriptionId String
  oldTier              String?
  newTier              String
  oldPriceId           String?
  newPriceId           String?

  // Event details
  eventType String // subscription_created, subscription_updated, subscription_canceled
  status    String // active, canceled, past_due, etc.

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId, tenantId])
}

model UsageEvent {
  id       String @id @default(cuid())
  userId   String
  tenantId String

  // Usage tracking
  action String // blueprint, export_pdf, integration_deploy, api_call
  month  String // YYYY-MM format for monthly limits

  // Context
  metadata String? // JSON string for additional context

  createdAt DateTime @default(now())

  @@index([userId, action, month])
  @@index([tenantId, action, month])
}
