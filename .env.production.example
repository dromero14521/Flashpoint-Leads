# =============================================================================
# AAA Platform - Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to git!
#
# For Railway deployment: Set these in Railway dashboard (Settings > Variables)
# For VPS deployment: Copy to server and source in docker-compose
# =============================================================================

# -----------------------------------------------------------------------------
# General Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
ENVIRONMENT=production
NEXT_PUBLIC_URL=https://apexautomation.ai

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://aaa:CHANGE_THIS_PASSWORD@postgres:5432/aaa_production

# Database credentials (for docker-compose)
POSTGRES_USER=aaa
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=aaa_production
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Clerk Authentication (Production Keys)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk webhook signing secret (for webhook verification)
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Stripe Payment Processing (Live Mode)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret (for webhook verification)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe product IDs (created via TASK-005)
STRIPE_PRODUCT_TIER1=prod_xxxxxxxxxxxxx
STRIPE_PRODUCT_TIER2=prod_xxxxxxxxxxxxx
STRIPE_PRODUCT_TIER3=prod_xxxxxxxxxxxxx

# Stripe price IDs
STRIPE_PRICE_TIER2_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_TIER2_ANNUAL=price_xxxxxxxxxxxxx
STRIPE_PRICE_TIER3=price_xxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# OpenRouter API (LLM Service)
# -----------------------------------------------------------------------------
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model selection by tier
OPENROUTER_MODEL_TIER1=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_TIER2=anthropic/claude-3-opus
OPENROUTER_MODEL_TIER3=anthropic/claude-3-opus

# Default model (fallback)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# -----------------------------------------------------------------------------
# GenAI Core Configuration
# -----------------------------------------------------------------------------
# URL for control-plane to reach genai-core
# Docker internal: http://genai-core:8000
# Railway: https://genai-core-production.up.railway.app
GENAI_CORE_URL=http://genai-core:8000

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking
# -----------------------------------------------------------------------------
# Sentry DSN (optional but recommended)
# Get from: https://sentry.io
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxx
SENTRY_ORG=apex-automation
SENTRY_PROJECT=aaa-platform

# Sentry sample rates
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# Email Service (Optional - for transactional emails)
# -----------------------------------------------------------------------------
# Choose: SendGrid, Postmark, AWS SES, Resend
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM_EMAIL=noreply@apexautomation.ai
SMTP_FROM_NAME=Apex Automation Architect

# -----------------------------------------------------------------------------
# Rate Limiting & Security
# -----------------------------------------------------------------------------
# API rate limiting (requests per minute)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# JWT secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features in production
FEATURE_FLAG_INTEGRATIONS=true
FEATURE_FLAG_API_ACCESS=true
FEATURE_FLAG_WHITE_GLOVE=true
FEATURE_FLAG_PDF_EXPORT=true

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# CDN & Storage (Optional)
# -----------------------------------------------------------------------------
# AWS S3 for file uploads (blueprints, exports)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=aaa-platform-production

# CloudFlare (if using CDN)
CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
# S3 bucket for database backups
BACKUP_S3_BUCKET=aaa-backups-production
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM UTC

# -----------------------------------------------------------------------------
# SSL/TLS Configuration (for VPS deployment)
# -----------------------------------------------------------------------------
# Let's Encrypt email for certificate renewal
LETSENCRYPT_EMAIL=admin@apexautomation.ai
DOMAIN_NAME=apexautomation.ai

# -----------------------------------------------------------------------------
# Custom Domain Configuration
# -----------------------------------------------------------------------------
# Primary domain
NEXT_PUBLIC_DOMAIN=apexautomation.ai

# Allowed origins for CORS
CORS_ORIGINS=https://apexautomation.ai,https://www.apexautomation.ai

# -----------------------------------------------------------------------------
# Railway-Specific (if using Railway)
# -----------------------------------------------------------------------------
# Railway will auto-inject these, but you can override:
# PORT=3000
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_ID=xxxxxxxxxxxxx
# RAILWAY_SERVICE_ID=xxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Docker-Specific (if using VPS)
# -----------------------------------------------------------------------------
# Docker compose project name
COMPOSE_PROJECT_NAME=aaa-platform

# Host timezone
TZ=UTC

# =============================================================================
# Security Notes
# =============================================================================
# 1. Rotate all secrets regularly (quarterly)
# 2. Use different secrets for staging vs production
# 3. Never log or expose environment variables in responses
# 4. Use secret management tools (Doppler, 1Password, AWS Secrets Manager)
# 5. Limit access to production secrets (only DevOps/CTO)
# =============================================================================
